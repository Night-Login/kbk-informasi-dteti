# ==========================================
# Local development (active by default)
# ==========================================
PORT=5000
NODE_ENV=development
FRONTEND_URLS="http://localhost:3000"

# Existing backend convention. Copy the local PostgreSQL URL from your private
# `.env`; never commit the real username/password.
DB_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME"

# ==========================================
# Optional Supabase target
# ==========================================
# Keep these empty while using DB_URL locally. When switching to Supabase,
# remove/empty DB_URL, then fill DATABASE_URL and DIRECT_URL.
DATABASE_URL=""
DIRECT_URL=""

# Supabase runtime example (Supavisor session mode, port 5432):
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"
#
# Supabase Prisma CLI example (direct connection, IPv6):
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
#
# One-time legacy import (set these only in the shell running the import):
# LEGACY_DATABASE_URL="postgresql://USER:PASSWORD@localhost:55432/LEGACY_DATABASE"
# TARGET_DATABASE_URL="postgresql://USER:PASSWORD@TARGET_HOST:5432/TARGET_DATABASE?sslmode=require"

# Keep the API pool conservative, especially when DATABASE_URL points to a
# managed pooler.
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000

# ==========================================
# JWT authentication
# ==========================================
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="2h"

# ==========================================
# Initial superadmin seeding
# ==========================================
SUPERADMIN_USERNAME="superadmin"
SUPERADMIN_PASSWORD="replace-with-a-strong-password"
